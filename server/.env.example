# Server Configuration
NODE_ENV=development
PORT=3000

# CORS Configuration
# Used by Express CORS and Better-Auth to allow requests from the client.
# Remember to change this to your Vercel frontend URL in production!
TRUSTED_ORIGIN=http://localhost:5173

# Database Connection (PostgreSQL)
# e.g. postgres://user:password@localhost:5432/webcraft
DATABASE_URL=""

# Authentication (Better-Auth)
BETTER_AUTH_SECRET="generate_a_random_secret_string"
# The URL where your server is running (Railway URL in prod)
BETTER_AUTH_URL=http://localhost:3000

# OpenAI API Key
AI_API_KEY=""
